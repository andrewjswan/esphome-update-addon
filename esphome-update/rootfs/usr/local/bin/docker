#!/command/with-contenv bashio
# ==============================================================================
# Home Assistant App: ESPHome Update
# This script gives the user instructions on how to enable Docker access.
# ==============================================================================
bashio::log.yellow "PROTECTION MODE ENABLED!"
bashio::log.yellow ""
bashio::log.yellow "To be able to use this command, you'll need to disable"
bashio::log.yellow "protection mode on this App. Without it, the App"
bashio::log.yellow "is unable to access Docker."
bashio::log.yellow ""
bashio::log.yellow "Steps:"
bashio::log.yellow " - Go to the Settings Panel."
bashio::log.yellow " - Enter the 'Apps' menu."
bashio::log.yellow " - Click on the ESPHome Update App."
bashio::log.yellow " - Set the 'Protection mode' switch to off."
bashio::log.yellow " - Restart the add-on."
bashio::log.yellow ""
bashio::log.yellow "Access to Docker allows you to do really powerful things"
bashio::log.yellow "including complete destruction of your system."
bashio::log.yellow "Please, be sure you know what you are doing before enabling"
bashio::log.yellow "this feature!"
bashio::log.yellow ""
